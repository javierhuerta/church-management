{
  "version": 2,
  "installCommand": "pip install -r requirements.txt --break-system-packages",
  "buildCommand": "python manage.py tailwind build && python manage.py collectstatic --noinput",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "church_management.settings_production"
  }
}
