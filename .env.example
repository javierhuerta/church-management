# ── Variables de entorno requeridas en producción (Vercel) ──────────────────
# Copia este archivo como .env para desarrollo local con PostgreSQL,
# o configura estas variables en el Dashboard de Vercel.

# Genera una clave segura con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=tu-clave-secreta-aqui

# URL de conexión a Neon PostgreSQL. Formato:
#   postgresql://usuario:contraseña@host.neon.tech/nombre_db?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Dominio(s) permitidos separados por coma (sin https://)
# Ej: church-management.vercel.app,mi-dominio-personalizado.com
ALLOWED_HOSTS=church-management.vercel.app
